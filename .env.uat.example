APP_ENV=uat
SERVICE_NAME=price-feed-uat
PUBLIC_BASE_URL=https://uat.example.com/ws
ALLOWED_ORIGINS=https://uat.example.com
WEBSOCKET_PORT=8081
STATIC_DIR=/app/web/static
DATA_DIR=/app/runtime/uat/raw-data
SFTP_LOCAL_PATH=/app/runtime/uat/raw-data
DOWNLOAD_INTERVAL_SECONDS=1
REDIS_ENABLED=true
REDIS_ADDR=price-feed-uat-redis:6379
REDIS_PASSWORD=uat_price_feed_redis_password
REDIS_DB=0
SFTP_HOST=
SFTP_PORT=22
SFTP_USER=
SFTP_PASSWORD=
SFTP_REMOTE_PATH=
SFTP_REMOTE_PATH2=
